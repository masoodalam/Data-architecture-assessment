{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "context-questions.schema.json",
  "title": "Context Questions",
  "description": "The context questions asked before the main assessment. These shape which recommendations are surfaced and how narrative is personalised.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "type", "label", "required", "storeAs"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "description": "Unique snake_case identifier for this question."
      },
      "type": {
        "type": "string",
        "enum": ["text", "select", "multi_select"],
        "description": "Input type rendered in the UI."
      },
      "label": {
        "type": "string",
        "minLength": 1,
        "description": "Question text displayed to the user."
      },
      "hint": {
        "type": "string",
        "description": "Optional help text shown beneath the question."
      },
      "placeholder": {
        "type": "string",
        "description": "Placeholder text for text inputs."
      },
      "required": {
        "type": "boolean",
        "description": "Whether the user must answer before proceeding."
      },
      "storeAs": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "description": "Key used to store the answer in application state and localStorage."
      },
      "options": {
        "type": "array",
        "description": "Required for select and multi_select types.",
        "minItems": 2,
        "items": {
          "type": "object",
          "required": ["value", "label"],
          "additionalProperties": false,
          "properties": {
            "value": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            },
            "label": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "if": {
      "properties": { "type": { "enum": ["select", "multi_select"] } }
    },
    "then": {
      "required": ["options"]
    }
  }
}
