{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tools-catalogue.schema.json",
  "title": "Tools Catalogue",
  "description": "Open-source-first catalogue of data tooling. Used to populate recommendation tool suggestions and alternative_tools lists.",
  "type": "object",
  "required": ["tools"],
  "additionalProperties": false,
  "properties": {
    "_comment": { "type": "string" },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "licence", "type", "deployment", "good_for", "url", "one_line"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Unique snake_case identifier referenced by recommendations."
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "metadata_catalogue",
              "data_quality",
              "oltp_database",
              "olap_database",
              "lakehouse_table_format",
              "ingestion",
              "transformation",
              "orchestration",
              "streaming",
              "bi_analytics",
              "semantic_layer",
              "security_access",
              "data_privacy",
              "ml_platform"
            ]
          },
          "licence": {
            "type": "string",
            "minLength": 1,
            "description": "Licence name. Be explicit about caveats (e.g. 'BSL 1.1 — converts to Apache 2.0 after 4 years')."
          },
          "type": {
            "type": "string",
            "enum": ["open_source", "commercial", "managed_service", "source_available"]
          },
          "deployment": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "self_hosted",
                "managed_saas",
                "managed_acryl",
                "managed_cloud",
                "aws_marketplace",
                "azure_marketplace",
                "gcp_marketplace",
                "embedded"
              ]
            }
          },
          "good_for": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "small_org",
                "medium_org",
                "large_org",
                "public_sector",
                "regulated_private",
                "aws",
                "azure",
                "gcp",
                "on_prem",
                "low_ops_overhead",
                "high_data_volume"
              ]
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Honest list of constraints or caveats a user should know before choosing this tool."
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "one_line": {
            "type": "string",
            "minLength": 10,
            "description": "A genuinely useful one-liner. Not marketing copy — describe what it does and the key trade-off."
          }
        }
      }
    }
  }
}
